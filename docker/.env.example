# =============================================================================
# Reeve — 환경 변수 설정 예시
# =============================================================================
# 사용법:
#   cp docker/.env.example docker/.env
#   docker/.env 파일을 열어 ★ 표시된 항목을 반드시 변경하세요.
#
# 플랫폼별 주의:
#   Linux/Windows (NVIDIA GPU) → docker-compose.dev.yml 사용
#   Mac (Apple Silicon)        → docker-compose.mac.yml 사용
#                                (EMBEDDING_DEVICE, OLLAMA_BASE_URL 등은
#                                 mac.yml에서 자동으로 override됨)
# =============================================================================


# =============================================================================
# [공통] Qdrant 벡터 데이터베이스
# =============================================================================
# Docker 내부 서비스 이름. 외부에서 접근 시 localhost로 변경.
QDRANT_HOST=qdrant
QDRANT_PORT=6333


# =============================================================================
# [공통] 임베딩 디바이스
# =============================================================================
# cuda  : Linux/Windows NVIDIA GPU (권장 — 속도 10배 이상 차이)
# cpu   : Mac Apple Silicon 또는 GPU 없는 환경
# ※ docker-compose.mac.yml을 사용하면 cpu로 자동 override됨
EMBEDDING_DEVICE=cuda


# =============================================================================
# [공통] 파일 업로드 제한
# =============================================================================
# MAX_UPLOAD_SIZE: 단일 이미지 최대 크기 (바이트). 기본 5MB = 5 * 1024 * 1024
MAX_UPLOAD_SIZE=5242880
# 허용 확장자 (쉼표 구분, 공백 없이)
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp


# =============================================================================
# [공통] 로깅
# =============================================================================
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# 컨테이너 내부 경로. ../logs/ 볼륨이 호스트와 마운트됨.
STUDIO_LOG_FILE=./logs/studio/service.log
IDENTIFIER_LOG_FILE=./logs/identifier/service.log


# =============================================================================
# [Studio] 기본 설정  (포트 8000 — 웹 UI 및 관리 API)
# =============================================================================
STUDIO_PORT=8000
# development | production
# production으로 설정 시 Swagger UI(/docs)가 비활성화됨
ENVIRONMENT=development


# =============================================================================
# [Studio] MySQL 데이터베이스
# =============================================================================
# Docker 내부 서비스 이름. 외부 DB 사용 시 호스트명으로 변경.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=reeve
# ★ 반드시 안전한 값으로 변경하세요
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_USER=reeve_user
MYSQL_PASSWORD=reeve_password_change_me


# =============================================================================
# [Studio] 비전 분석 백엔드
# =============================================================================
# 차량 이미지 사전 분석(제조사·모델 추출)에 사용할 AI 백엔드 선택
# openai : OpenAI GPT Vision API 사용 (인터넷 필요, 유료)
# ollama : 로컬 Ollama VLM 사용 (인터넷 불필요, GPU 메모리 필요)
VISION_BACKEND=openai

# --- OpenAI (VISION_BACKEND=openai 일 때 필수) ---
# ★ OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
# 사용할 GPT 모델. Vision 기능 지원 모델이어야 함.
OPENAI_MODEL=gpt-5-mini

# --- Google Gemini (교차 검증용 — 선택 사항) ---
# 설정 시 OpenAI + Gemini 두 결과가 일치해야만 분석 성공으로 처리됨
# 두 결과가 불일치하면 분석 실패로 처리되어 정확도가 높아지는 대신 처리량이 줄어듦
# 교차 검증이 필요 없으면 빈 값으로 두세요.
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# --- Studio Ollama VLM (VISION_BACKEND=ollama 일 때 사용) ---
# Identifier의 VLM 설정(VLM_MODEL_NAME)과 별개로 Studio에서 독립적으로 설정
STUDIO_VLM_MODEL=qwen3-vl:8b
# Studio VLM 요청 타임아웃(초). 복잡한 이미지는 처리 시간이 길 수 있음.
STUDIO_VLM_TIMEOUT=60


# =============================================================================
# [Studio] 모델명 매칭 알고리즘
# =============================================================================
# AI가 반환한 차량명과 DB에 등록된 모델명을 퍼지 매칭으로 비교
# FUZZY_MATCH_THRESHOLD: 0~100 정수. 높을수록 엄격. 80 권장.
FUZZY_MATCH_THRESHOLD=80


# =============================================================================
# [Studio] 분석 데이터 자동 정리
# =============================================================================
# 오래된 분석 결과(AnalyzedVehicle)를 자동 삭제해 DB 용량을 관리
CLEANUP_ENABLED=true
# 분석 결과 보존 기간(일). 이 기간이 지난 항목은 자동 삭제됨.
ANALYZED_VEHICLES_RETENTION_DAYS=30
# 매일 정리 작업을 실행할 시각 (0~23, 서버 시간 기준). 트래픽이 적은 새벽 권장.
CLEANUP_HOUR=3


# =============================================================================
# [Identifier] 기본 설정  (포트 8001 — 차량 판별 ML 파이프라인)
# =============================================================================
IDENTIFIER_PORT=8001

# 판별 파이프라인 모드 선택:
#   efficientnet : EfficientNetV2-M 분류 → 신뢰도 ≥ CLASSIFIER_CONFIDENCE_THRESHOLD면 즉시 반환,
#                  미만이면 Qwen3-VL로 폴백 (속도·정확도 균형, 기본 권장)
#   visual_rag   : EfficientNet 임베딩 → Qdrant 검색 → 항상 Qwen3-VL로 최종 판별
#                  (정확도 최우선, GPU 메모리 및 처리 시간 증가)
#   vlm_only     : YOLO 크롭 → Qwen3-VL만 사용 (EfficientNet·Qdrant 미사용,
#                  파인튜닝 데이터가 부족할 때 유용)
IDENTIFIER_MODE=efficientnet


# =============================================================================
# [Trainer] 백엔드 설정  (포트 8002 — 파인튜닝 API)
# =============================================================================
# ★ IDENTIFIER_MODE와 반드시 일치시켜야 함
#   efficientnet → TRAINER_BACKEND=efficientnet
#                  (Mac/Linux/Windows 공통, PyTorch가 MPS·CUDA·CPU를 자동 감지)
#   visual_rag / vlm_only → TRAINER_BACKEND=llamafactory (Linux/Windows)
#                            TRAINER_BACKEND=mlx          (Mac — start.sh에서 자동 설정)
TRAINER_BACKEND=efficientnet

# 학습 데이터 디렉터리. Docker 컨테이너 내부 경로는 /app/data로 고정됨.
TRAINER_DATA_DIR=data/finetune
# VLM 학습 체크포인트 출력 디렉터리. Docker 컨테이너 내부는 /app/output으로 고정됨.
TRAINER_OUTPUT_DIR=data/checkpoints/vlm
# VLM export 후 병합 모델 저장 디렉터리. Docker 컨테이너 내부는 /app/models/vlm으로 고정됨.
VLM_MODEL_DIR=data/models/vlm
# Trainer 서비스 로그 디렉터리
TRAINER_LOG_DIR=logs/trainer


# =============================================================================
# [Identifier / Trainer] VLM — Ollama (Qwen3-VL)
# =============================================================================
# Ollama 서버 URL. Docker 내부에서는 http://ollama:11434 사용.
# Mac에서 Ollama를 네이티브로 실행하는 경우 docker-compose.mac.yml이
# http://host.docker.internal:11434 로 자동 override함.
OLLAMA_BASE_URL=http://ollama:11434

# Identifier가 판별에 사용하는 VLM 모델명.
# ollama-init 컨테이너가 이 값을 참조해 모델을 자동으로 Pull함.
VLM_MODEL_NAME=qwen3-vl:8b

# Ollama KV 캐시 크기 (토큰 수).
# 기본값(256K)은 VRAM 약 36 GB를 소모하므로 차량 이미지 분석 용도에 맞게 축소.
#   4096  → ~0.6 GB VRAM (최소)
#   8192  → ~1.1 GB VRAM (권장)
#   16384 → ~2.2 GB VRAM (고해상도 이미지 다량 처리 시)
OLLAMA_NUM_CTX=8192

# VLM 단일 요청 타임아웃(초). GPU 성능에 따라 조정.
VLM_TIMEOUT=30
# VLM에 전달할 최대 후보 차량 수. 많을수록 정확하지만 프롬프트가 길어짐.
VLM_MAX_CANDIDATES=5
# VLM 호출 실패 시 임베딩 결과로 폴백할지 여부
VLM_FALLBACK_TO_EMBEDDING=true
# 배치 작업 시 VLM 동시 요청 수. VRAM이 충분하면 높여도 됨.
VLM_BATCH_CONCURRENCY=2


# =============================================================================
# [Identifier] 판별 파라미터
# =============================================================================
# Qdrant에서 가져올 유사 이미지 후보 수. 많을수록 투표 정확도가 올라가지만 느려짐.
IDENTIFIER_TOP_K=10

# EfficientNetV2-M 분류기 "identified" 판정 최소 신뢰도 (0.0 ~ 1.0).
# 0으로 설정하면 IDENTIFIER_CONFIDENCE_THRESHOLD 값을 자동 사용 (기본 0.80).
# 파인튜닝 모델 사용 시 0(자동) 권장.
CLASSIFIER_CONFIDENCE_THRESHOLD=0

# EfficientNetV2-M 분류기에서 VLM 폴백으로 내려가는 최소 신뢰도 (0.0 ~ 1.0).
# 신뢰도 3단계 판정:
#   ≥ CLASSIFIER_CONFIDENCE_THRESHOLD (0.80) → "identified" 반환
#   ≥ CLASSIFIER_LOW_CONFIDENCE_THRESHOLD   → "low_confidence" 반환 (VLM 없음)
#   < CLASSIFIER_LOW_CONFIDENCE_THRESHOLD   → VLM 폴백 실행
CLASSIFIER_LOW_CONFIDENCE_THRESHOLD=0.40

# Qdrant 검색 결과 신뢰도 임계값 (0.0 ~ 1.0).
# 최종 식별 결과가 이 값 미만이면 "낮은 신뢰도" 경고와 함께 반환됨.
IDENTIFIER_CONFIDENCE_THRESHOLD=0.80

# Qdrant 유사도 최솟값 (0.0 ~ 1.0). 이 값 미만의 검색 결과는 후보에서 제외.
IDENTIFIER_MIN_SIMILARITY=0.70

# 투표 기반 판별에서 동의해야 할 최소 후보 수. TOP_K보다 작아야 함.
IDENTIFIER_VOTE_THRESHOLD=3
# 투표 집중도 임계값. 특정 모델에 투표가 집중될수록 신뢰도가 높아짐 (0.0 ~ 1.0).
IDENTIFIER_VOTE_CONCENTRATION_THRESHOLD=0.3

# YOLO를 이용한 차량 영역 감지 활성화 여부.
# true로 설정하면 차량 부분만 잘라내어 정확도가 향상됨.
IDENTIFIER_VEHICLE_DETECTION=true
# YOLO 감지 신뢰도 임계값 (0.0 ~ 1.0). 낮을수록 더 많은 영역을 감지하지만 오탐 증가.
IDENTIFIER_YOLO_CONFIDENCE=0.25
# 감지된 차량 경계 상자에 추가할 여백 (픽셀). 너무 작으면 차량 일부가 잘릴 수 있음.
IDENTIFIER_CROP_PADDING=10

# YOLO가 차량을 감지하지 못했을 때의 동작:
# false (기본) : 원본 이미지 전체로 판별 계속 진행
# true         : 오류 반환 (차량 이미지가 보장된 환경에서만 사용)
IDENTIFIER_REQUIRE_VEHICLE_DETECTION=false


# =============================================================================
# [Identifier] 성능 튜닝
# =============================================================================
# PyTorch CPU 스레드 수. CPU 코어 수에 맞게 조정. GPU 사용 시 영향 적음.
IDENTIFIER_TORCH_THREADS=8
# 단일 배치 처리 이미지 수. GPU 메모리에 맞게 조정.
IDENTIFIER_BATCH_SIZE=32
# 배치 API 엔드포인트에서 허용하는 최대 파일 수
IDENTIFIER_MAX_BATCH_FILES=100
# 배치 API 최대 업로드 크기 (바이트). 기본 100MB = 100 * 1024 * 1024.
IDENTIFIER_MAX_BATCH_UPLOAD_SIZE=104857600
# torch.compile() 최적화 활성화. 첫 실행 시 컴파일에 수십 초 소요되지만 이후 속도 향상.
# Mac(ARM) 에서는 불안정할 수 있으므로 docker-compose.mac.yml에서 false로 override됨.
IDENTIFIER_ENABLE_TORCH_COMPILE=true


# =============================================================================
# [Identifier] Redis / Celery (배치 비동기 처리)
# =============================================================================
# Docker 내부 서비스 이름. 외부 Redis 사용 시 호스트명으로 변경.
REDIS_HOST=redis
REDIS_PORT=6379
# Redis DB 번호 (0~15). 다른 용도의 Redis와 공유 시 번호를 분리할 것.
REDIS_DB=0

# Celery 태스크 하드 타임아웃(초). 이 시간이 지나면 강제 종료됨.
CELERY_TASK_TIME_LIMIT=600
# Celery 태스크 소프트 타임아웃(초). 이 시간이 지나면 SoftTimeLimitExceeded 예외 발생.
# 하드 타임아웃보다 약간 작게 설정해 정리 작업 시간을 확보.
CELERY_TASK_SOFT_TIME_LIMIT=540
# 태스크 실패 시 최대 재시도 횟수
CELERY_MAX_RETRIES=3


# =============================================================================
# [서비스 간 URL] 네이티브(비 Docker) 실행 시에만 수정
# =============================================================================
# Docker 환경에서는 docker-compose.yml이 내부 서비스 이름(http://studio:8000 등)으로
# 자동 override하므로 이 값을 변경할 필요 없음.
# Docker 없이 로컬에서 각 서비스를 직접 실행할 때만 아래 값을 수정하세요.
TRAINER_URL=http://localhost:8002
IDENTIFIER_URL=http://localhost:8001
STUDIO_URL=http://localhost:8000
