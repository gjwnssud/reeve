# ──────────────────────────────────────────
# Common Settings (studio + identifier 공유)
# ──────────────────────────────────────────

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Embedding
# Linux/Windows(NVIDIA GPU): cuda / Mac(Apple Silicon): cpu (docker-compose.mac.yml에서 자동 override됨)
EMBEDDING_DEVICE=cuda

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Logging
LOG_LEVEL=INFO
STUDIO_LOG_FILE=./logs/studio/service.log
IDENTIFIER_LOG_FILE=./logs/identifier/service.log

# ──────────────────────────────────────────
# Studio Settings (개발/관리용 - port 8000)
# ──────────────────────────────────────────

STUDIO_PORT=8000
ENVIRONMENT=development

# MySQL Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=reeve
MYSQL_USER=reeve_user
MYSQL_PASSWORD=reeve_password_change_me

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# Google Gemini API (교차 검증용 — 설정 시 ChatGPT+Gemini 두 결과가 일치해야 분석 성공)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Matching Algorithm
FUZZY_MATCH_THRESHOLD=80
CONFIDENCE_THRESHOLD=0.8

# Data Lifecycle Management
ANALYZED_VEHICLES_RETENTION_DAYS=30
CLEANUP_ENABLED=true
CLEANUP_HOUR=3

# ──────────────────────────────────────────
# Identifier Settings (차량 판별 서비스 - port 8001)
# ──────────────────────────────────────────

IDENTIFIER_PORT=8001

# 판별 모드
# efficientnet: EfficientNetV2-M 분류 → 신뢰도 ≥ 0.9 즉시 반환, 미만 시 Qwen3-VL 폴백
# visual_rag  : EfficientNet 임베딩 → Qdrant 검색 → 항상 Qwen3-VL 최종 판별
# vlm_only    : YOLO 크롭 후 Qwen3-VL만으로 판별 (Qdrant/임베딩 미사용)
IDENTIFIER_MODE=efficientnet

# Trainer 백엔드 — IDENTIFIER_MODE와 반드시 일치시킬 것
# efficientnet → TRAINER_BACKEND=efficientnet  (Mac/Linux/Windows 공통, PyTorch MPS/CUDA/CPU 자동 감지)
# visual_rag / vlm_only → TRAINER_BACKEND=llamafactory (Linux/Windows) | mlx (Mac, start.sh에서 자동 설정)
# ※ Mac은 start.sh가 IDENTIFIER_MODE를 읽어 자동 결정하므로 이 값을 직접 참조하지 않음
TRAINER_BACKEND=efficientnet

# VLM (Ollama)
OLLAMA_BASE_URL=http://ollama:11434
VLM_MODEL_NAME=qwen3-vl:8b
VLM_TIMEOUT=30
VLM_MAX_CANDIDATES=5
VLM_FALLBACK_TO_EMBEDDING=true
VLM_BATCH_CONCURRENCY=2

# 판별 파라미터
IDENTIFIER_TOP_K=10
IDENTIFIER_CONFIDENCE_THRESHOLD=0.80
IDENTIFIER_MIN_SIMILARITY=0.70
IDENTIFIER_VOTE_THRESHOLD=3
IDENTIFIER_VOTE_CONCENTRATION_THRESHOLD=0.3
IDENTIFIER_VEHICLE_DETECTION=true
IDENTIFIER_YOLO_CONFIDENCE=0.25
IDENTIFIER_CROP_PADDING=10

# 성능
IDENTIFIER_TORCH_THREADS=8
IDENTIFIER_BATCH_SIZE=32
IDENTIFIER_MAX_BATCH_FILES=100
IDENTIFIER_MAX_BATCH_UPLOAD_SIZE=104857600
IDENTIFIER_ENABLE_TORCH_COMPILE=true

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_MAX_RETRIES=3
